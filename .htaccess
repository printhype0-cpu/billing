Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine On

# Explicit default index to avoid 403 when directory listing is disabled
DirectoryIndex index.html index.htm

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Serve existing files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Allow Next.js static assets
RewriteRule ^_next/ - [L]
RewriteRule ^static/ - [L]
RewriteRule ^assets/ - [L]

# Single Page App fallback
RewriteRule ^ index.html [L]
</IfModule>

# Optional caching for static assets
<IfModule mod_headers.c>
<FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot)$">
Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
</IfModule>
